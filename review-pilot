## 9. Comprehensive JSON Schema Blueprint (Flexible Rubrics & Logs)
This raw JSON structure provides a highly flexible schema for a relational/document database system, allowing it to adapt to variable corporate formats.
## 9.1 The Evaluation Rubric Template Schema (evaluation_rubrics)
This schema models any company's goals, conditions, and multi-tier scoring rules within a flexible JSON object:

{
  "$schema": "https://json-schema.org",
  "title": "EvaluationRubricTemplate",
  "type": "object",
  "properties": {
    "rubric_id": { "type": "string", "format": "uuid" },
    "organization_name": { "type": "string" },
    "cycle_period": { "type": "string", "example": "2025-2026" },
    "scoring_type": { "type": "string", "enum": ["NUMERIC", "ALPHA", "TEXTUAL"] },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "goal_id": { "type": "string" },
          "goal_title": { "type": "string" },
          "weight_percentage": { "type": "integer" },
          "core_requirements": {
            "type": "array",
            "items": { "type": "string" }
          },
          "scoring_matrix": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "score_tier": { "type": "string", "example": "5/Exceptional" },
                "min_actions_required": { "type": "integer" },
                "explicit_criteria_keywords": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "description": { "type": "string" }
              },
              "required": ["score_tier", "description"]
            }
          }
        },
        "required": ["goal_id", "goal_title", "scoring_matrix"]
      }
    }
  },
  "required": ["rubric_id", "organization_name", "cycle_period", "goals"]
}

